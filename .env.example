# 应用配置
APP_NAME="GPT Team 管理系统"
APP_VERSION="0.1.0"
APP_HOST="0.0.0.0"
APP_PORT=8008
DEBUG=False  # 本地调试可临时改为 True，生产环境必须为 False

# 数据库配置
DATABASE_URL="sqlite+aiosqlite:///./team_manage.db"

# 安全配置
SECRET_KEY="replace-with-a-64-char-random-string"
ADMIN_PASSWORD="replace-with-a-strong-initial-password"  # 首次登录后请立即修改
ADMIN_PATH="/replace-with-a-long-random-admin-path"  # 留空时会基于 SECRET_KEY 自动生成隐藏路径

# 日志配置
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
DATABASE_ECHO=False  # 是否打印 SQL 语句

# 代理配置 (可选)
PROXY=""  # 格式: http://host:port 或 socks5://host:port 或 socks5://user:pass@host:port
PROXY_ENABLED=False

# JWT 配置
JWT_VERIFY_SIGNATURE=False  # 开发环境可设为 False,生产环境建议设为 True

# 时区配置
TIMEZONE=Asia/Shanghai  # 默认使用中国时区
